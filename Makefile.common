Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_i2c.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_jpeg.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_ltdc_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_ltdc.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_mdma.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_ospi.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_pwr_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_pwr.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_rcc_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_rcc.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_rtc_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_rtc.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_sai_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_sai.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_spi_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_spi.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_tim.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_tim_ex.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal_wwdg.h \
Drivers/STM32H7xx_HAL_Driver/Inc/stm32h7xx_hal.h \


#######################################
# binaries
#######################################
PREFIX = arm-none-eabi-
# The gcc compiler bin path can be either defined in make command via GCC_PATH variable (> make GCC_PATH=xxx)
# either it can be added to the PATH environment variable.
ifdef GCC_PATH
CC   = $(GCC_PATH)/$(PREFIX)gcc
CXX  = $(GCC_PATH)/$(PREFIX)g++
AS   = $(GCC_PATH)/$(PREFIX)gcc -x assembler-with-cpp
CP   = $(GCC_PATH)/$(PREFIX)objcopy
SZ   = $(GCC_PATH)/$(PREFIX)size
GDB  = $(GCC_PATH)/$(PREFIX)gdb
DUMP = $(GCC_PATH)/$(PREFIX)objdump
else
CC   = $(PREFIX)gcc
CXX  = $(PREFIX)g++
AS   = $(PREFIX)gcc -x assembler-with-cpp
CP   = $(PREFIX)objcopy
SZ   = $(PREFIX)size
GDB  = $(PREFIX)gdb
DUMP = $(PREFIX)objdump
endif

HEX   = $(CP) -O ihex
BIN   = $(CP) -O binary -S
ECHO  = echo
TOUCH = touch

#######################################
# CFLAGS
#######################################
# cpu
CPU = -mcpu=cortex-m7 -mtune=cortex-m7

# fpu
FPU = -mfpu=fpv5-d16

# float-abi
FLOAT-ABI = -mfloat-abi=hard

# mcu
MCU = $(CPU) -mthumb -mno-unaligned-access $(FPU) $(FLOAT-ABI)

# macros for gcc
# AS defines
AS_DEFS +=

# C defines
C_DEFS +=  \
-D_GNU_SOURCE \
-DINTERNAL_CORE_BIN_HEADER_VERSION=$(INTERNAL_CORE_BIN_HEADER_VERSION) \
-DINTFLASH_BANK=$(INTFLASH_BANK) \
-DINTFLASH_ADDRESS=$(INTFLASH_ADDRESS) \
-DBIG_BANK=$(BIG_BANK) \
-DEXTFLASH_SIZE=$(EXTFLASH_SIZE) \
-DMSX_USE_BANK_2=$(MSX_USE_BANK_2) \
-DOFF_SAVESTATE=$(OFF_SAVESTATE) \
-DCODEPAGE=$(CODEPAGE) \
-DUICODEPAGE=$(UICODEPAGE) \
-DINCLUDED_ES_ES=$(ES_ES) \
-DINCLUDED_PT_PT=$(PT_PT) \
-DINCLUDED_FR_FR=$(FR_FR) \
-DINCLUDED_IT_IT=$(IT_IT) \
-DINCLUDED_DE_DE=$(DE_DE) \
-DINCLUDED_RU_RU=$(RU_RU) \
-DINCLUDED_ZH_CN=$(ZH_CN) \
-DINCLUDED_ZH_TW=$(ZH_TW) \
-DINCLUDED_KO_KR=$(KO_KR) \
-DINCLUDED_JA_JP=$(JA_JP) \
-DSINGLE_FONT=$(SINGLE_FONT) \
-DLANG=$(LANG) \
-DCOVERFLOW=$(COVERFLOW) \
-DEXTFLASH_FORCE_SPI=$(EXTFLASH_FORCE_SPI) \
-DUSE_HAL_DRIVER \
-DSTM32H7B0xx \
-DIS_LITTLE_ENDIAN \
-DDEBUG_RG_ALLOC \
-DENABLE_SCREENSHOT=$(ENABLE_SCREENSHOT) \
-DSD_CARD=$(SD_CARD) \
-DCHEAT_CODES=$(CHEAT_CODES) \
-DDISABLE_SPLASH_SCREEN=$(DISABLE_SPLASH_SCREEN) \
-DENABLE_BOOT_OC=$(ENABLE_BOOT_OC) \
-DTARGET_GNW \
-DNO_EMBEDDED_SAMPLES \
-D__LIBRETRO__ \
-DZ80_CUSTOM_CONFIGURATION \
-DMSX_NO_ZIP \
-DMSX_NO_FILESYSTEM \
-DMSX_NO_MALLOC \
-DMAX_VIDEO_WIDTH_320 \
-DPIXEL_WIDTH=8 \
-DMSX_NO_STEREO \
-DFCEU_VERSION_NUMERIC=9813 \
-DFCEU_LOW_RAM \
-DFCEU_NO_MALLOC \
-DVIDEO_RGB565 \
-DCELESTE_SLOW_CPU

ifdef MAX_CHEAT_CODES
C_DEFS += -DMAX_CHEAT_CODES=$(MAX_CHEAT_CODES)
endif

# AS includes
AS_INCLUDES +=

# C includes
C_INCLUDES +=  \
-ICore/Inc \
-ICore/Inc/porting \
-ICore/Inc/porting/gb \
-ICore/Inc/porting/gb_tgbdual \
-ICore/Inc/porting/nes \
-ICore/Inc/porting/nes_fceu \
-ICore/Inc/porting/smsplusgx \
-ICore/Inc/porting/pce \
-ICore/Inc/porting/msx \
-ICore/Inc/porting/wsv \
-ICore/Inc/porting/gw \
-ICore/Inc/porting/gwenesis \
-ICore/Inc/porting/a2600 \
-ICore/Inc/porting/a7800 \
-ICore/Inc/porting/amstrad \
-ICore/Inc/porting/zelda3 \
-ICore/Inc/porting/smw \
-ICore/Inc/porting/videopac \
-ICore/Inc/porting/celeste \
-ICore/Inc/porting/pico8 \
-ICore/Inc/porting/tama \
-ICore/Inc/porting/pkmini \
-ICore/Inc/retro-go \
-IDrivers/STM32H7xx_HAL_Driver/Inc \
-IDrivers/STM32H7xx_HAL_Driver/Inc/Legacy \
-IDrivers/CMSIS/Device/ST/STM32H7xx/Include \
-IDrivers/CMSIS/Include \
-Iretro-go-stm32/components/lupng \

CXX_INCLUDES += \

CFLAGS += $(CFLAGS_EXTRA)

# compile gcc flags
ASFLAGS += $(MCU) $(AS_DEFS) $(AS_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections

CFLAGS += $(MCU) $(C_DEFS) $(C_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections -falign-functions -falign-jumps -fmerge-all-constants

ifeq ($(DEBUG), 1)
CFLAGS += -ggdb -gdwarf-2
endif

CFLAGS += -fstack-usage -Wstack-usage=20480

# Generate dependency information
CFLAGS += -MMD -MP -MF"$(@:%.o=%.d)"

CXXFLAGS = $(CFLAGS) $(CXX_INCLUDES) \
-fno-rtti \
-fno-math-errno \
-fomit-frame-pointer \
-fno-stack-protector \
-fno-threadsafe-statics \
-nostartfiles \
-DHAVE_STDINT_H \
-Wno-error=format-truncation

LDFLAGS += -Wl,--defsym=__EXTFLASH_OFFSET__=$(EXTFLASH_OFFSET)
LDFLAGS += -Wl,--defsym=__EXTFLASH_TOTAL_LENGTH__=$(EXTFLASH_TOTAL_LENGTH)
LDFLAGS += -Wl,--defsym=ENABLE_SCREENSHOT=$(ENABLE_SCREENSHOT)
LDFLAGS += -Wl,--defsym=__FILESYSTEM_OFFSET__=$(FILESYSTEM_OFFSET)
LDFLAGS += -Wl,--defsym=__FILESYSTEM_LENGTH__=$(FILESYSTEM_SIZE)

LDFLAGS += -Wl,--defsym=__INTFLASH__=$(INTFLASH_ADDRESS)

ifeq ($(BIG_BANK), 1)
	FLASH_LENGTH = 256k
else
	FLASH_LENGTH = 128k
endif

LDFLAGS += -Wl,--defsym=__FLASH_LENGTH__=$(FLASH_LENGTH)

#######################################
# LDFLAGS
#######################################
# link script
ifeq ($(SD_CARD), 0)
LDSCRIPT ?= STM32H7B0VBTx_FLASH.ld
else
LDSCRIPT ?= STM32H7B0VBTx_SDCARD.ld
endif

# libraries
LIBS = -lc -lm -lnosys
CXXLIBS = -lstdc++
LIBDIR +=
LDFLAGS += $(MCU) -specs=nano.specs -T$(LDSCRIPT) $(LIBDIR) $(LIBS) $(CXXLIBS) -Wl,-Map=$(BUILD_DIR)/$(TARGET).map,--cref -Wl,--gc-sections
LDFLAGS += -Wl,--wrap=fflush

# default action: build all (FrogFS has no gw_*_extflash.bin payload — flash frogfs.bin instead)
ifeq ($(DOCKER),1)
all: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) -j$$(nproc) all $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
all: CheckTools CheckDirtySubmodules $(BUILD_DIR) $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET)_intflash.bin $(BUILD_DIR)/$(TARGET)_intflash2.bin
ifneq ($(SD_CARD),0)
all: $(BUILD_DIR)/$(TARGET)_extflash.bin
endif
ifeq ($(SD_CARD),0)
all: $(FROGFS_IMAGE)
endif
endif

#######################################
# build the application
#######################################
# list of objects
OBJECTS = $(addprefix $(BUILD_DIR)/core/,$(notdir $(C_SOURCES:.c=.o) $(SDK_C_SOURCES:.c=.o)))
FATFS_OBJECTS = $(addprefix $(BUILD_DIR)/fatfs/,$(notdir $(FATFS_C_SOURCES:.c=.o)))
TAMP_OBJECTS = $(addprefix $(BUILD_DIR)/tamp/,$(notdir $(TAMP_C_SOURCES:.c=.o)))
TGBDUAL_OBJECTS = $(addprefix $(BUILD_DIR)/tgbdual/,$(notdir $(TGBDUAL_C_SOURCES:.c=.o)))
NES_OBJECTS = $(addprefix $(BUILD_DIR)/nes/,$(notdir $(NES_C_SOURCES:.c=.o)))
NES_FCEU_OBJECTS = $(addprefix $(BUILD_DIR)/nes_fceu/,$(notdir $(NES_FCEU_C_SOURCES:.c=.o)))
SMSPLUSGX_OBJECTS = $(addprefix $(BUILD_DIR)/smsplusgx/,$(notdir $(SMSPLUSGX_C_SOURCES:.c=.o)))
PCE_OBJECTS = $(addprefix $(BUILD_DIR)/pce/,$(notdir $(PCE_C_SOURCES:.c=.o)))
GW_OBJECTS = $(addprefix $(BUILD_DIR)/gw/,$(notdir $(GW_C_SOURCES:.c=.o)))
MSX_OBJECTS = $(addprefix $(BUILD_DIR)/msx/,$(notdir $(MSX_C_SOURCES:.c=.o)))
WSV_OBJECTS = $(addprefix $(BUILD_DIR)/wsv/,$(notdir $(WSV_C_SOURCES:.c=.o)))
MD_OBJECTS = $(addprefix $(BUILD_DIR)/md/,$(notdir $(MD_C_SOURCES:.c=.o)))
A2600_OBJECTS = $(addprefix $(BUILD_DIR)/a2600/,$(notdir $(A2600_C_SOURCES:.c=.o)))
A7800_OBJECTS = $(addprefix $(BUILD_DIR)/a7800/,$(notdir $(A7800_C_SOURCES:.c=.o)))
AMSTRAD_OBJECTS = $(addprefix $(BUILD_DIR)/amstrad/,$(notdir $(AMSTRAD_C_SOURCES:.c=.o)))
ZELDA3_OBJECTS = $(addprefix $(BUILD_DIR)/zelda3/,$(notdir $(ZELDA3_C_SOURCES:.c=.o)))
SMW_OBJECTS = $(addprefix $(BUILD_DIR)/smw/,$(notdir $(SMW_C_SOURCES:.c=.o)))
VIDEOPAC_OBJECTS = $(addprefix $(BUILD_DIR)/videopac/,$(notdir $(VIDEOPAC_C_SOURCES:.c=.o)))
CELESTE_OBJECTS = $(addprefix $(BUILD_DIR)/celeste/,$(notdir $(CELESTE_C_SOURCES:.c=.o)))
PICO8_ALL_SOURCES = $(PICO8_C_SOURCES) $(PICO8_CXX_SOURCES) $(PICO8_CXX_STUBS)
PICO8_OBJECTS = $(addprefix $(BUILD_DIR)/pico8/,$(notdir $(patsubst %.cpp,%.o,$(patsubst %.c,%.o,$(PICO8_ALL_SOURCES)))))
TAMA_OBJECTS = $(addprefix $(BUILD_DIR)/tama/,$(notdir $(TAMA_C_SOURCES:.c=.o)))
PKMINI_OBJECTS = $(addprefix $(BUILD_DIR)/pkmini/,$(notdir $(PKMINI_C_SOURCES:.c=.o)))

vpath %.c $(sort $(dir $(C_SOURCES) $(FATFS_C_SOURCES) $(TAMP_C_SOURCES) $(NES_C_SOURCES) $(NES_FCEU_C_SOURCES) $(TGBDUAL_C_SOURCES) $(TGBDUAL_C_SOURCES) $(SMSPLUSGX_C_SOURCES) $(PCE_C_SOURCES) $(MSX_C_SOURCES) $(GW_C_SOURCES) $(WSV_C_SOURCES) $(MD_C_SOURCES) $(A2600_C_SOURCES) $(A7800_C_SOURCES) $(AMSTRAD_C_SOURCES) $(ZELDA3_C_SOURCES) $(SMW_C_SOURCES) $(VIDEOPAC_C_SOURCES) $(CELESTE_C_SOURCES) $(TAMA_C_SOURCES) $(PKMINI_C_SOURCES) $(PICO8_C_SOURCES) $(SDK_C_SOURCES)))
# Guard empty lists: vpath with empty path resets the pattern's search path.
# The GPL stub build has no PICO8_CXX_SOURCES, so only emit these when non-empty.
ifneq ($(strip $(PICO8_CXX_SOURCES)),)
vpath %.c $(sort $(dir $(PICO8_CXX_SOURCES)))
endif
ifneq ($(strip $(PICO8_CXX_SOURCES) $(PICO8_CXX_STUBS)),)
vpath %.cpp $(sort $(dir $(PICO8_CXX_SOURCES) $(PICO8_CXX_STUBS)))
endif

MAPPER_SRCS := $(wildcard external/fceumm-go/src/boards/*.c)
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/__%.c, $(MAPPER_SRCS))
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/fceu-emu2413.c, $(MAPPER_SRCS))
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/mmc3.c, $(MAPPER_SRCS))
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/latch.c, $(MAPPER_SRCS))
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/vrcirq.c, $(MAPPER_SRCS))
MAPPER_SRCS := $(filter-out external/fceumm-go/src/boards/eeprom_93C66.c, $(MAPPER_SRCS))
MAPPER_NAMES := $(notdir $(basename $(subst -,_,$(MAPPER_SRCS))))

# CXX
CXX_OBJECTS =          $(addprefix $(BUILD_DIR)/core/,$(notdir $(CXX_SOURCES:.cpp=.o) ))
TGBDUAL_CXX_OBJECTS = $(addprefix $(BUILD_DIR)/tgbdual/,$(notdir $(TGBDUAL_CXX_SOURCES:.cpp=.o)))
A2600_CXX_OBJECTS = $(addprefix $(BUILD_DIR)/a2600/,$(notdir $(A2600_CXX_SOURCES:.cxx=.o)))

vpath %.cpp $(sort $(dir $(CXX_SOURCES) $(TGBDUAL_CXX_SOURCES) ))
vpath %.cxx $(sort $(dir $(A2600_CXX_SOURCES) ))

# list of ASM program objects
OBJECTS += $(addprefix $(BUILD_DIR)/,$(notdir $(SDK_ASM_SOURCES:.s=.o)))
OBJECTS += $(BUILD_DIR)/memcpy-armv7m.o
vpath %.s $(sort $(dir $(SDK_ASM_SOURCES)))

# function used to generate prerequisite rules for SDK objects
define sdk_obj_prereq_gen
$(BUILD_DIR)/$(patsubst %.c,%.o,$(patsubst %.s,%.o,$(notdir $1))): $1

endef
# note: the blank line above is intentional

# generate all object prerequisite rules
$(eval $(foreach obj,$(SDK_C_SOURCES) $(SDK_ASM_SOURCES),$(call sdk_obj_prereq_gen,$(obj))))

FORCE:

Core/Inc/gittag.h: FORCE | $(BUILD_DIR)
	$(V)./scripts/update_gittag.sh $@

$(BUILD_DIR)/core/error_screens.o: Core/Inc/gittag.h
$(BUILD_DIR)/core/main.o: Core/Inc/gittag.h
$(BUILD_DIR)/core/rg_main.o: Core/Inc/gittag.h
$(BUILD_DIR)/core/rg_emulators.o: Core/Inc/gittag.h

# Run parse_roms.py to generate information about the roms
$(BUILD_DIR)/rom_files.txt: FORCE | $(BUILD_DIR)
	$(V)$(ECHO) [ BASH ] Checking for updated roms

ifeq (${CHECK_DIRTY_SUBMODULE},1)
CheckDirtySubmodules:
	$(V)git submodule foreach "git diff --quiet" 2> /dev/null || \
		(echo -e "\n\n\nYou have changes in the submodule. This is not normal.\nPlease clean the submodule by running 'git submodule update --init'\n\n(You may set CHECK_DIRTY_SUBMODULE=0 to suppress this warning)\n\n\n" && exit 1)
	$(V)git submodule status | grep -v '+' 2> /dev/null > /dev/null || \
		(echo -e "\n\n\nYou are using a submodule that is not updated.\nPlease sync the submodules by running 'git submodule update --init'\n\n(You may set CHECK_DIRTY_SUBMODULE=0 to suppress this warning)\n\n\n" && exit 1)
else
CheckDirtySubmodules:
endif
.PHONY: CheckDirtySubmodules

PrepareFceummMappers:
	$(V)$(PYTHON3) external/fceumm-go/gen_mappers_ld.py

ifeq (${CHECK_TOOLS},1)
CheckTools:
	@# Check that the tools in the toolchain exist
	$(V)/usr/bin/env bash -c " \
		for tool in $(CC) $(CP) $(SZ) $(DUMP); do \
		which \$$tool 2> /dev/null > /dev/null || \
		( \
			echo -e \"\nCannot find \$$tool\n\" && \
			exit 1 \
		) \
		done"

	@# Check that GCC version 10 or higher is used
	$(V)$(CC) -v 2>&1 | grep "gcc version 1[0-9]" > /dev/null || \
		( \
			echo -e "\n\n\nPlease use GCC version 10 or higher.\n\n\nYou are using:" && \
			$(CC) -v 2>&1 | grep "gcc version" ; \
			echo -e "\n\n\n" && \
			exit 1 \
		)

	$(V)$(CP) --info | grep "elf32-littlearm" > /dev/null || \
		( \
			echo -e "\n\n\n$(CP) does not suport elf32-littlearm.\nPlease install a toolchain that supports elf32-littlearm and armv7e-m.\n\n\n" && \
			exit 1 \
		)

	$(V)$(DUMP) --help | grep "armv7e-m" > /dev/null || \
		( \
			echo -e "\n\n\nobjdump does not suport armv7e-m.\nPlease install a toolchain that supports elf32-littlearm and armv7e-m.\n\n\n" && \
			exit 1 \
		)

	$(V)$(PYTHON3) scripts/python_version_check.py

else
CheckTools:
endif
.PHONY: CheckTools

$(BUILD_DIR)/%.o: %.s Makefile.common Makefile | $(BUILD_DIR)
	$(V)$(ECHO) [ AS ] $(notdir $<)
	$(V)$(AS) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/memcpy-armv7m.o: Core/Src/memcpy-armv7m.s Makefile.common Makefile | $(BUILD_DIR)
	$(V)$(ECHO) [ AS ] $(notdir $<)
	$(V)$(AS) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) $(FATFS_OBJECTS) $(TAMP_OBJECTS) $(A7800_OBJECTS) $(NES_OBJECTS) $(NES_FCEU_OBJECTS) $(TGBDUAL_OBJECTS) $(SMSPLUSGX_OBJECTS) $(PCE_OBJECTS) $(MSX_OBJECTS) $(GW_OBJECTS) $(WSV_OBJECTS) $(MD_OBJECTS) $(AMSTRAD_OBJECTS) $(VIDEOPAC_OBJECTS) $(CELESTE_OBJECTS) $(CXX_OBJECTS) $(TGBDUAL_CXX_OBJECTS) $(A2600_OBJECTS) $(A2600_CXX_OBJECTS) $(ZELDA3_OBJECTS) $(SMW_OBJECTS) $(TAMA_OBJECTS) $(PKMINI_OBJECTS) $(PICO8_OBJECTS) Makefile.common Makefile PrepareFceummMappers $(LDSCRIPT)
	$(V)$(ECHO) [ LD ] $(notdir $@)
	$(V)$(CC) $(OBJECTS) $(FATFS_OBJECTS) $(TAMP_OBJECTS) $(A7800_OBJECTS) $(NES_OBJECTS) $(NES_FCEU_OBJECTS) $(TGBDUAL_OBJECTS) $(SMSPLUSGX_OBJECTS) $(PCE_OBJECTS) $(MSX_OBJECTS) $(GW_OBJECTS) $(WSV_OBJECTS) $(MD_OBJECTS) $(AMSTRAD_OBJECTS) $(VIDEOPAC_OBJECTS) $(CELESTE_OBJECTS) $(CXX_OBJECTS) $(TGBDUAL_CXX_OBJECTS) $(A2600_OBJECTS) $(A2600_CXX_OBJECTS) $(ZELDA3_OBJECTS) $(SMW_OBJECTS) $(TAMA_OBJECTS) $(PKMINI_OBJECTS) $(PICO8_OBJECTS) $(LDFLAGS) -o $@

$(BUILD_DIR)/core/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC core ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/core/$(notdir $(<:.c=.lst)) $< -o $@

ifeq ($(SD_CARD), 1)
$(BUILD_DIR)/fatfs/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC FatFs ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(FATFS_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/fatfs/$(notdir $(<:.c=.lst)) $< -o $@
endif

ifneq ($(SD_CARD), 1)
$(TAMP_OBJECTS): $(BUILD_DIR)/tamp/%.o: $(TAMP_DIR)tamp/%.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC tamp ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(TAMP_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/tamp/$(notdir $(<:.c=.lst)) $< -o $@
endif

$(BUILD_DIR)/nes/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC nes ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(NES_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/nes/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/nes_fceu/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC nes-fceu ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(NES_FCEU_C_INCLUDES) -Wno-sequence-point -Wno-parentheses -Wa,-a,-ad,-alms=$(BUILD_DIR)/nes_fceu/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/tgbdual/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC GB TGB Dual ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(TGBDUAL_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/tgbdual/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/smsplusgx/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC sms ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(SMSPLUSGX_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/smsplusgx/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/pce/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC pce ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(PCE_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/pce/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/msx/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC msx ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(MSX_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/msx/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/gw/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC gw ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(GW_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/gw/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/wsv/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC wsv ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(WSV_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/wsv/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/md/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC md ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(MD_C_DEFS) $(MD_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/md/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/a7800/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC a7800 ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(A7800_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/a7800/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/a2600/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC a2600 ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(A2600_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/a2600/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/amstrad/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC amstrad CPC ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(AMSTRAD_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/amstrad/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/videopac/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC o2em ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(VIDEOPAC_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/videopac/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/celeste/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC celeste ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(CELESTE_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/celeste/$(notdir $(<:.c=.lst)) $< -o $@

# PICO-8: ALL sources compiled as C++ (z8lua .c files require C++ for fix32.h)
# Extra flags: -fno-exceptions since we don't use them.
# NOTE: -flto and blanket -O3 overflow the linker memory sections on STM32.
# Also: lvm.c (bytecode dispatch loop) MUST stay at -O2 — at -O3 the loop
# inlines aggressively enough to exceed the Cortex-M7 16 KB I-cache, causing
# branch-prediction misses and net SLOWDOWN. This is the known interpreter
# dispatch pathology and is why LuaJIT/V8/etc all use -O2 for their dispatch
# loops.
# ltable.c has no dispatch loop and is safe to compile at -O3.
# GPL stub: compiled as C++ (main_pico8_stub.c uses extern "C"), no objcopy rename needed.
# The full engine build (closed repo) overrides these rules with its own Makefile
# that includes the ABI redefine step.
PICO8_EXTRA_FLAGS = -fno-exceptions

$(BUILD_DIR)/pico8/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CXX pico8 ] $(notdir $<)
	$(V)$(CXX) -c $(CXXFLAGS) $(PICO8_EXTRA_FLAGS) $(PICO8_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/pico8/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/tama/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC tama ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(TAMA_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/tama/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/pkmini/%.o: %.c Makefile.common Makefile $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CC Pokemon Mini ] $(notdir $<)
	$(V)$(CC) -c $(CFLAGS) $(PKMINI_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/pkmini/$(notdir $(<:.c=.lst)) $< -o $@

# CXX
$(BUILD_DIR)/core/%.o: %.cpp Makefile Makefile.common $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CXX core ] $(notdir $<)
	$(V)$(CXX) -c $(CXXFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/core/$(notdir $(<:.cpp=.lst)) $< -o $@

$(BUILD_DIR)/tgbdual/%.o: %.cpp Makefile Makefile.common $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CXX GB TGB Dual ] $(notdir $<)
	$(V)$(CXX) -c $(CXXFLAGS) $(TGBDUAL_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/tgbdual/$(notdir $(<:.cpp=.lst)) $< -o $@

$(BUILD_DIR)/a2600/%.o: %.cxx Makefile Makefile.common $(SDK_HEADERS) | $(BUILD_DIR)
	$(V)$(ECHO) [ CXX a2600 ] $(notdir $<)
	$(V)$(CXX) -c $(CXXFLAGS) $(A2600_C_INCLUDES) -Wa,-a,-ad,-alms=$(BUILD_DIR)/a2600/$(notdir $(<:.cxx=.lst)) $< -o $@

# Zelda3 configuration

# Limit to 30 fps for improved stability
ZELDA3_LIMIT_30FPS ?= 1

# Increase UI speed (item menu, etc.)
ZELDA3_FASTER_UI ?= 1

# Display battery indicator in item menu
ZELDA3_BATTERY_INDICATOR ?= 1

# Item switch on L/R. Also allows reordering of items in inventory by pressing Y+direction.
# Hold X, L, or R inside of the item selection screen to assign items to those buttons.
# If X is reassigned, Select opens the map. Push Select while paused to save or quit.
# When L or R are assigned items, those buttons will no longer cycle items.
ZELDA3_FEATURE_SWITCH_LR ?= 0
# Allow turning while dashing
ZELDA3_FEATURE_TURN_WHILE_DASHING ?= 0
# Allow mirror to be used to warp to the Dark World
ZELDA3_FEATURE_MIRROR_TO_DARK_WORLD ?= 0
# Collect items (like hearts) with sword instead of having to touch them
ZELDA3_FEATURE_COLLECT_ITEMS_WITH_SWORD ?= 0
# Level 2-4 sword can be used to break pots
ZELDA3_FEATURE_BREAK_POTS_WITH_SWORD ?= 0
# Disable the low health beep
ZELDA3_FEATURE_DISABLE_LOW_HEALTH_BEEP ?= 0
# Avoid waiting too much at the start
ZELDA3_FEATURE_SKIP_INTRO_ON_KEYPRESS ?= 1
# Display max rupees/bombs/arrows with orange/yellow color
ZELDA3_FEATURE_SHOW_MAX_ITEMS_IN_YELLOW ?= 0
# Allows up to four bombs active at a time instead of two.
ZELDA3_FEATURE_MORE_ACTIVE_BOMBS ?= 0
# Can carry 9999 rupees instead of 999
ZELDA3_FEATURE_CARRY_MORE_RUPEES ?= 0
# Enable various zelda bug fixes
ZELDA3_FEATURE_MISC_BUG_FIXES ?= 0
# Allow bird travel to be cancelled by hitting the X key
ZELDA3_FEATURE_CANCEL_BIRD_TRAVEL ?= 0
# Enable some more advanced zelda bugfixes that change game behavior
ZELDA3_FEATURE_GAME_CHANGING_BUG_FIXES ?= 0
# Enable this to limit the ItemSwitchLR item cycling to the first 4 items.
ZELDA3_FEATURE_SWITCH_LR_LIMIT ?= 0

ZELDA3_FEATURES := 0
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_SWITCH_LR) << 1 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_TURN_WHILE_DASHING) << 2 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_MIRROR_TO_DARK_WORLD) << 3 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_COLLECT_ITEMS_WITH_SWORD) << 4 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_BREAK_POTS_WITH_SWORD) << 5 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_DISABLE_LOW_HEALTH_BEEP) << 6 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_SKIP_INTRO_ON_KEYPRESS) << 7 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_SHOW_MAX_ITEMS_IN_YELLOW) << 8 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_MORE_ACTIVE_BOMBS) << 9 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_CARRY_MORE_RUPEES) << 11 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_MISC_BUG_FIXES) << 12 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_CANCEL_BIRD_TRAVEL) << 13 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_GAME_CHANGING_BUG_FIXES) << 14 ))")
ZELDA3_FEATURES := $(shell echo "$$(( $(ZELDA3_FEATURES) | $(ZELDA3_FEATURE_SWITCH_LR_LIMIT) << 15 ))")

# C defines for zelda3
C_DEFS_ZELDA3 =  \
-DHEADLESS \
-DLIMIT_30FPS=$(ZELDA3_LIMIT_30FPS) \
-DFEATURES=$(ZELDA3_FEATURES) \
-DFASTER_UI=$(ZELDA3_FASTER_UI) \
-DBATTERY_INDICATOR=$(ZELDA3_BATTERY_INDICATOR) \

# function used to generate prerequisite rules for zelda3 objects
define zelda3_obj_prereq_gen
$$(BUILD_DIR)/zelda3/$(patsubst %.c,%.o,$(notdir $1)): $1 Makefile.common Makefile $$(SDK_HEADERS) | $$(BUILD_DIR)
	$$(V)$$(ECHO) [ CC zelda3 ] $$(notdir $$<)
	$$(V)$$(CC) -c $$(CFLAGS) $$(C_DEFS_ZELDA3) $$(ZELDA3_C_INCLUDES)-Wa,-a,-ad,-alms=$$(BUILD_DIR)/zelda3/$$(notdir $$(<:.c=.lst)) $$< -o $$@ \
	-Wno-parentheses -Wno-unknown-pragmas -Wno-incompatible-pointer-types -Wno-unused-const-variable -Wno-strict-aliasing -Wno-comment -Wno-unused-function -Wno-stack-usage -Wno-int-in-bool-context -Wno-unused-variable -Wno-unused-but-set-variable
	$$(V)$$(CP) --redefine-syms=zelda3_redefines $$@

endef
# note: the blank line above is intentional

# generate all zelda3 object prerequisite rules
$(eval $(foreach obj,$(ZELDA3_C_SOURCES),$(call zelda3_obj_prereq_gen,$(obj))))

# SMW configuration

# Limit to 30 fps for improved stability
SMW_LIMIT_30FPS ?= 1

# Save to SRAM after each beaten level (instead of saving after castle is beaten).
# SRAM save remains valid/compatible with emulators.
SMW_FEATURE_SAVE_AFTER_EACH_BEATEN_LEVEL ?= 0

SMW_FEATURES := 0
SMW_FEATURES := $(shell echo "$$(( $(SMW_FEATURES) | $(SMW_FEATURE_SAVE_AFTER_EACH_BEATEN_LEVEL) << 0 ))")

# C defines for smw
C_DEFS_SMW =  \
-DHEADLESS \
-DLIMIT_30FPS=$(SMW_LIMIT_30FPS) \
-DFEATURES=$(SMW_FEATURES) \

# function used to generate prerequisite rules for smw objects
define smw_obj_prereq_gen
$$(BUILD_DIR)/smw/$(patsubst %.c,%.o,$(notdir $1)): $1 Makefile.common Makefile $$(SDK_HEADERS) | $$(BUILD_DIR)
	$$(V)$$(ECHO) [ CC smw ] $$(notdir $$<)
	$$(V)$$(CC) -c $$(CFLAGS) $$(C_DEFS_SMW) $$(SMW_C_INCLUDES) -Wa,-a,-ad,-alms=$$(BUILD_DIR)/smw/$$(notdir $$(<:.c=.lst)) $$< -o $$@ \
	-Wno-parentheses -Wno-unknown-pragmas -Wno-unused-variable -Wno-unused-but-set-variable -Wno-unused-const-variable -Wno-int-in-bool-context -Wno-unused-value -Wno-unused-function -Wno-incompatible-pointer-types -Wno-implicit-function-declaration -Wno-format -Wno-array-bounds -Wno-strict-aliasing -Wno-maybe-uninitialized
	$$(V)$$(CP) --redefine-syms=smw_redefines $$@

endef
# note: the blank line above is intentional

# generate all smw object prerequisite rules
$(eval $(foreach obj,$(SMW_C_SOURCES),$(call smw_obj_prereq_gen,$(obj))))

external/smw/smw_assets.dat: roms/smw/smw.sfc | $(BUILD_DIR)
	cp $< external/smw/assets/smw.sfc
	$(MAKE) -C external/smw smw_assets.dat

$(BUILD_DIR):
	$(V)mkdir $@
	$(V)mkdir $@/core
	$(V)mkdir $@/cores
	$(V)mkdir $@/fatfs
	$(V)mkdir $@/tamp
	$(V)mkdir $@/nes
	$(V)mkdir $@/nes_fceu
	$(V)mkdir $@/tgbdual
	$(V)mkdir $@/smsplusgx
	$(V)mkdir $@/pce
	$(V)mkdir $@/msx
	$(V)mkdir $@/gw
	$(V)mkdir $@/wsv
	$(V)mkdir $@/md
	$(V)mkdir $@/a2600
	$(V)mkdir $@/a7800
	$(V)mkdir $@/amstrad
	$(V)mkdir $@/zelda3
	$(V)mkdir $@/smw
	$(V)mkdir $@/videopac
	$(V)mkdir $@/celeste
	$(V)mkdir $@/pico8
	$(V)mkdir $@/tama
	$(V)mkdir $@/pkmini

#######################################
# Flashing
#######################################

ADAPTER ?= stlink

reset:
	@$(GNWMANAGER) start bank1
.PHONY: reset

erase_intflash_1:
	@$(GNWMANAGER) erase bank1
.PHONY: erase_intflash_1

erase_intflash_2:
	@$(GNWMANAGER) erase bank2
.PHONY: erase_intflash_2

erase_extflash:
	@echo "Erasing External Flash..."
	@$(GNWMANAGER) erase ext
	@echo "Erasing Complete!"
.PHONY: erase_extflash

erase_all:
	@echo "Erasing Internal & External Flash..."
	@$(GNWMANAGER) erase all
	@echo "Erasing Complete!"
.PHONY: erase_all

start_bank_1:
	$(GNWMANAGER) start bank1
.PHONY: start_bank_1

start_bank_2:
	$(GNWMANAGER) start bank2
.PHONY: start_bank_2

start:  # Start code located at INTFLASH_ADDRESS
	$(GNWMANAGER) start $(INTFLASH_ADDRESS)
.PHONY: start


ifeq ($(DOCKER),1)
flash_intflash: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) flash_intflash $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
flash_intflash: $(BUILD_DIR)/$(TARGET)_intflash.bin
	$(GNWMANAGER) flash $(INTFLASH_ADDRESS) $< -- start $(INTFLASH_ADDRESS)
endif
.PHONY: flash_intflash


ifeq ($(DOCKER),1)
flash_extflash: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) flash_extflash $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
flash_extflash:
ifeq ($(SD_CARD), 0)
	@$(MAKE) --no-print-directory $(FROGFS_IMAGE) $(LITTLEFS_IMAGE)
	$(GNWMANAGER) flash ext $(FROGFS_IMAGE) --offset=$(EXTFLASH_OFFSET) \
		-- flash ext $(LITTLEFS_IMAGE) --offset=$(FILESYSTEM_FLASH_OFFSET) \
		-- start $(INTFLASH_ADDRESS)
endif
endif
.PHONY: flash_extflash

# Programs both the external and internal flash.
ifeq ($(DOCKER),1)
flash: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) flash $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
flash: CheckTools CheckDirtySubmodules $(BUILD_DIR)/$(TARGET)_intflash.bin $(if $(filter-out 0,$(SD_CARD)),$(BUILD_DIR)/$(TARGET)_extflash.bin,)
ifeq ($(SD_CARD), 0)
	@$(MAKE) --no-print-directory $(FROGFS_IMAGE) $(LITTLEFS_IMAGE)
	$(GNWMANAGER) flash $(INTFLASH_ADDRESS) $(BUILD_DIR)/$(TARGET)_intflash.bin \
		-- flash ext $(FROGFS_IMAGE) --offset=$(EXTFLASH_OFFSET) \
		-- flash ext $(LITTLEFS_IMAGE) --offset=$(FILESYSTEM_FLASH_OFFSET) \
		-- start $(INTFLASH_ADDRESS) \
		$(RESET_DBGMCU_CMD);
else
	@$(GNWMANAGER) flash $(INTFLASH_ADDRESS) $(BUILD_DIR)/$(TARGET)_intflash.bin \
		-- start $(INTFLASH_ADDRESS) \
		$(RESET_DBGMCU_CMD)
endif
endif
.PHONY: flash

# Upload cores to sd card
SD_FOLDER := sd_content
CORES_DIR := $(SD_FOLDER)/cores
FONTS_DIR := $(SD_FOLDER)/fonts
UNICODE_FONT_SOURCE ?= assets/fonts/fusion-pixel-12px-monospaced-zh_hant.ttf
# tools/gen_unicode_bin.py --script names → /fonts/unicode_<name>.bin (trimmed by active UI langs)
UNICODE_FONT_SCRIPTS := greek math_operators geometric misc_symbols
ifneq ($(filter 1,$(ZH_CN) $(ZH_TW) $(JA_JP) $(KO_KR)),)
# CJK Unified Ideographs (kanji / hanzi / hanja) + punctuation/fullwidth blocks
UNICODE_FONT_SCRIPTS += cjk_punct fullwidth cjk
endif
ifeq ($(JA_JP),1)
UNICODE_FONT_SCRIPTS += hiragana katakana
endif
ifeq ($(KO_KR),1)
UNICODE_FONT_SCRIPTS += hangul
endif
UNICODE_FONT_BINS := $(addprefix $(FONTS_DIR)/unicode_, $(addsuffix .bin, $(UNICODE_FONT_SCRIPTS)))
MAPPERS_DIR := $(CORES_DIR)/mappers
HOMEBREWS_FOLDER := $(SD_FOLDER)/roms/homebrew
RELEASE_FOLDER := release

define EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER
	@tmp_file="$2.tmp"; \
	version_lo=$$(( $(INTERNAL_CORE_BIN_HEADER_VERSION) & 0xFF )); \
	version_hi=$$(( ($(INTERNAL_CORE_BIN_HEADER_VERSION) >> 8) & 0xFF )); \
	git_tag=$$(sed -n 's/^#define GIT_TAG "\(.*\)"/\1/p' Core/Inc/gittag.h); \
	tag_len=$${#git_tag}; \
	if [ $$tag_len -gt 255 ]; then echo "CORE: internal git tag too long ($$tag_len > 255)"; rm -f "$$tmp_file"; exit 1; fi; \
	header_len=$$((1 + tag_len)); \
	header_len_lo=$$(( header_len & 0xFF )); \
	header_len_hi=$$(( (header_len >> 8) & 0xFF )); \
	$(CP) -O binary --only-section=$1 $(BUILD_DIR)/$(TARGET).elf "$$tmp_file" && \
	{ printf 'CORI'; \
	  printf "\\x$$(printf '%02x' $$version_lo)\\x$$(printf '%02x' $$version_hi)\\x$$(printf '%02x' $$header_len_lo)\\x$$(printf '%02x' $$header_len_hi)"; \
	  printf "\\x$$(printf '%02x' $$tag_len)"; \
	  printf '%s' "$$git_tag"; \
	  cat "$$tmp_file"; } > "$2" && \
	rm -f "$$tmp_file"
endef

$(MAPPERS_DIR)/mapper_%.bin: $(BUILD_DIR)/$(TARGET).elf
	@$(CP) -O binary --only-section=.overlay_nes_fceu_$* $< $@

MAPPER_BINS := $(addprefix $(MAPPERS_DIR)/mapper_, $(addsuffix .bin, $(MAPPER_NAMES)))

create_sd_folders:
	$(V)mkdir -p $(SD_FOLDER)
	$(V)mkdir -p $(CORES_DIR)
	$(V)mkdir -p $(FONTS_DIR)
	$(V)mkdir -p $(CORES_DIR)
	$(V)mkdir -p $(MAPPERS_DIR)
	$(V)mkdir -p $(SD_FOLDER)/bios
	$(V)mkdir -p $(SD_FOLDER)/bios/msx
	$(V)mkdir -p $(SD_FOLDER)/bios/nes
	$(V)mkdir -p $(SD_FOLDER)/bios/coleco
	$(V)mkdir -p $(HOMEBREWS_FOLDER)
	$(V)mkdir -p $(RELEASE_FOLDER)

prepare_msx_bios_files: create_sd_folders
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX2.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX2EXT.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX2P.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX2PEXT.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSX2PMUS.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSXDOS23.ROM" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/MSXKANJI.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/PANASONICDISK.rom" $(SD_FOLDER)/bios/msx/
	@cp "external/blueMSX-go/system/bluemsx/Machines/Shared Roms/SUNRISEIDE.rom" $(SD_FOLDER)/bios/msx/
    # PANASONICDISK_.rom is a patched version of PANASONICDISK.rom to disable the 2nd FDD
    # this is allowing to free some ram, which is needed for some games. It could be done by pressing
    # ctrl key at boot using original bios, but using this patched version, the user will have nothing
    # to do. Unfortunately this version can't be used in all cases because some games (from Micro Cabin)
    # like Fray, XAK III, ... are expecting the 2nd FDD to be present.
	@cp $(SD_FOLDER)/bios/msx/PANASONICDISK.rom $(SD_FOLDER)/bios/msx/PANASONICDISK_.rom
	@printf '\x00' | dd of=$(SD_FOLDER)/bios/msx/PANASONICDISK_.rom bs=1 seek=6124 count=1 conv=notrunc status=none

$(FONTS_DIR)/unicode_%.bin: $(UNICODE_FONT_SOURCE) tools/gen_unicode_bin.py | create_sd_folders
	@echo "Generating $@ from $(UNICODE_FONT_SOURCE)"
	@$(PYTHON3) tools/gen_unicode_bin.py "$(UNICODE_FONT_SOURCE)" --script "$*" -o "$@"

create_sd_data: create_sd_folders prepare_msx_bios_files $(MAPPER_BINS) $(BUILD_DIR)/$(TARGET)_intflash.bin
	@$(PYTHON3) external/fceumm-go/gen_mappers_table.py $(MAPPERS_DIR)/mappers_table.bin
	@$(PYTHON3) external/fceumm-go/gen_ines_database.py $(MAPPERS_DIR)/ines_correct.bin
	@$(PYTHON3) tools/gen_fceu_palettes_table.py $(SD_FOLDER)/bios/nes/palettes.bin
	@$(PYTHON3) external/stella2014-go/convert_defprops.py external/stella2014-go/stella/src/emucore/DefProps.hxx $(CORES_DIR)/a2600_defprops.bin
	@$(PYTHON3) external/blueMSX-go/create_compact_database_file.py external/blueMSX-go/system/bluemsx/Databases/msxromdb.xml $(SD_FOLDER)/bios/msx/msxromdb.bin
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_nes_fceu,$(CORES_DIR)/nes_fceu.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_tgb,$(CORES_DIR)/tgb.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_sms,$(CORES_DIR)/sms.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_pce,$(CORES_DIR)/pce.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_msx,$(CORES_DIR)/msx.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_wsv,$(CORES_DIR)/wsv.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_gw,$(CORES_DIR)/gw.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_md,$(CORES_DIR)/md.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_a2600,$(CORES_DIR)/a2600.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_a7800,$(CORES_DIR)/a7800.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_amstrad,$(CORES_DIR)/amstrad.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_videopac,$(CORES_DIR)/videopac.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_tama,$(CORES_DIR)/tama.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_pkmini,$(CORES_DIR)/pkmini.bin)
	$(call EXTRACT_INTERNAL_CORE_BIN_WITH_HEADER,.overlay_pico8,$(CORES_DIR)/pico8_stub.bin)
	@$(CP) -O binary --only-section=.overlay_celeste $(BUILD_DIR)/$(TARGET).elf $(HOMEBREWS_FOLDER)/celeste.bin
	@$(CP) -O binary --only-section=.overlay_zelda3 $(BUILD_DIR)/$(TARGET).elf "$(HOMEBREWS_FOLDER)/Zelda 3.bin"
	@$(CP) -O binary --only-section=.rodata_zelda3 $(BUILD_DIR)/$(TARGET).elf "$(HOMEBREWS_FOLDER)/zelda3.ro"
	@$(CP) -O binary --only-section=.overlay_smw $(BUILD_DIR)/$(TARGET).elf "$(HOMEBREWS_FOLDER)/Super Mario World.bin"
	@$(CP) -O binary --only-section=.coleco_bios_data $(BUILD_DIR)/$(TARGET).elf $(SD_FOLDER)/bios/coleco/coleco.bin
	@$(CP) -O binary --only-section=.overlay_graphics $(BUILD_DIR)/$(TARGET).elf $(SD_FOLDER)/bios/logo.bin
	@rm -f $(FONTS_DIR)/cp1251_*.bin $(FONTS_DIR)/cp1252_*.bin $(FONTS_DIR)/unicode_*.bin
ifeq ($(RU_RU),1)
	@$(CP) -O binary --only-section=.sd_fonts_cp1251_serif $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1251_serif.bin
ifneq ($(SINGLE_FONT),1)
	@$(CP) -O binary --only-section=.sd_fonts_cp1251_greybeard $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1251_greybeard.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1251_sans_serif_bold $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1251_sans_serif_bold.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1251_sans_serif $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1251_sans_serif.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1251_serif_bold $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1251_serif_bold.bin
endif
endif
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_serif $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_serif.bin
ifneq ($(SINGLE_FONT),1)
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_greybeard $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_greybeard.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_haeberli12 $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_haeberli12.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_rock12 $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_rock12.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_sans_serif_bold $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_sans_serif_bold.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_sans_serif $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_sans_serif.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_serif_bold $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_serif_bold.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_serif_cjk $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_serif_cjk.bin
	@$(CP) -O binary --only-section=.sd_fonts_cp1252_unbalanced $(BUILD_DIR)/$(TARGET).elf $(FONTS_DIR)/cp1252_unbalanced.bin
endif

	@$(V)cp build/gw_retro_go_intflash.bin $(SD_FOLDER)/update_bank2.bin
	@$(MAKE) --no-print-directory $(UNICODE_FONT_BINS)

# SD_CARD=0: pico8.ro is packed in FrogFS (post-patched for XiP); do not duplicate from GNW ZIP on LittleFS.
FROGFS_PICO8_FLAGS := $(if $(filter 0,$(SD_CARD)),\
	--bundle-pico8-ro-in-frogfs --extflash-base 0x90000000 --extflash-offset $(EXTFLASH_OFFSET),)
LITTLEFS_OMIT_PICO8_RO := $(if $(filter 0,$(SD_CARD)),--omit-pico8-ro-from-gnw-zip,)

# SD_CARD=0: optional FrogFS ROM LZMA pack (scripts/rom_frogfs_lzma.py); align with COMPRESS=lzma.
FROGFS_ROM_LZMA_FLAGS := $(if $(filter 0,$(SD_CARD)),$(if $(filter-out 0,$(COMPRESS)),--rom-compression $(COMPRESS),),)
# Omit /covers from FrogFS unless COVERFLOW=1 (matches firmware COVERFLOW define).
FROGFS_COVERS_FLAGS := $(if $(filter 1,$(COVERFLOW)),,--no-covers)

$(FROGFS_IMAGE): create_sd_data scripts/gen_frogfs_image.py scripts/rom_frogfs_lzma.py scripts/frogfs_pico8_ro.py scripts/pico8_ro_build_patch.py scripts/pico8_gnw_cores.py scripts/sd_cores_pack.py tools/gencovers.py external/zelda3/tables/restool.py external/smw/assets/restool.py $(FROGFS_DIR)/tools/mkfrogfs.py
	$(V)$(PYTHON3) scripts/gen_frogfs_image.py \
		--sd-content $(SD_FOLDER) \
		--output $@ \
		--build-dir $(FROGFS_BUILD_DIR) \
		--reserve-size $(EXTFLASH_TOTAL_LENGTH) \
		$(FROGFS_PICO8_FLAGS) \
		$(FROGFS_ROM_LZMA_FLAGS) \
		$(FROGFS_COVERS_FLAGS)

frogfs_image: $(FROGFS_IMAGE)
.PHONY: frogfs_image

$(LITTLEFS_IMAGE): create_sd_data scripts/gen_littlefs_image.py scripts/sd_cores_pack.py scripts/nes_rom_mappers.py scripts/pico8_gnw_cores.py
	$(V)$(PYTHON3) scripts/gen_littlefs_image.py \
		--sd-content $(SD_FOLDER) \
		--output $@ \
		--build-dir $(LITTLEFS_BUILD_DIR) \
		--size $(FILESYSTEM_SIZE) \
		--block-size $(LITTLEFS_BLOCK_SIZE) \
		$(LITTLEFS_OMIT_PICO8_RO)

littlefs_image: $(LITTLEFS_IMAGE)
.PHONY: littlefs_image

ifeq ($(DOCKER),1)
flash_sd: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) flash_sd $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
flash_sd: CheckTools CheckDirtySubmodules $(BUILD_DIR)/$(TARGET)_intflash.bin create_sd_data
	$(eval MAPPERS_SDPUSH := $(foreach mapper,$(MAPPER_NAMES),-- sdpush --file $(MAPPERS_DIR)/mapper_$(mapper).bin --dest-path "/cores/mappers/"))
	@$(GNWMANAGER) flash $(INTFLASH_ADDRESS) $(BUILD_DIR)/$(TARGET)_intflash.bin \
		-- sdpush --file $(CORES_DIR)/nes_fceu.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/tgb.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/sms.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/pce.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/msx.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/wsv.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/gw.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/md.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/a2600.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/a2600_defprops.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/a7800.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/amstrad.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/videopac.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/tama.bin --dest-path "/cores/" \
		-- sdpush --file $(CORES_DIR)/pkmini.bin --dest-path "/cores/" \
		-- sdpush --file $(SD_FOLDER)/bios/logo.bin --dest-path "/bios/" \
		-- sdpush --file $(HOMEBREWS_FOLDER)/celeste.bin --dest-path "/roms/homebrew/" \
		-- sdpush --file "$(HOMEBREWS_FOLDER)/Super Mario World.bin" --dest-path "/roms/homebrew/" \
		-- sdpush --file "$(HOMEBREWS_FOLDER)/Zelda 3.bin" --dest-path "/roms/homebrew/" \
		-- sdpush --file "$(HOMEBREWS_FOLDER)/zelda3.ro" --dest-path "/roms/homebrew/" \
		-- sdpush --file $(MAPPERS_DIR)/mappers_table.bin --dest-path "/cores/mappers/" \
		-- sdpush --file $(MAPPERS_DIR)/ines_correct.bin --dest-path "/cores/mappers/" \
		-- sdpush --file $(SD_FOLDER)/bios/nes/palettes.bin --dest-path "/bios/nes/" \
		-- sdpush --file $(SD_FOLDER)/bios/coleco/coleco.bin --dest-path "/bios/coleco" \
		-- sdpush --file $(SD_FOLDER)/bios/msx/msxromdb.bin --dest-path "/bios/msx/" \
		$(MAPPERS_SDPUSH) \
		-- start $(INTFLASH_ADDRESS) \
		$(RESET_DBGMCU_CMD)
endif

firmware_update: create_sd_folders
	@$(MAKE) -j$(nproc) -C external/firmware_update
	@cp external/firmware_update/build/firmware_update.bin $(RELEASE_FOLDER)/

# Release is SD_CARD=1 only; SD_CARD=0 builds require proprietary blobs and
# cannot produce a distributable release package.
ifeq ($(DOCKER),1)
release: FORCE
ifeq ($(SD_CARD),0)
	$(error release target requires SD_CARD=1)
endif
	$(V)$(DOCKER_RUN) $(MAKE) -j$$(nproc) release $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
release: CheckTools CheckDirtySubmodules $(BUILD_DIR)/$(TARGET)_intflash.bin create_sd_data firmware_update
ifeq ($(SD_CARD),0)
	$(error release target requires SD_CARD=1; SD_CARD=0 builds require proprietary blobs and cannot produce a distributable release)
endif
	@tar --format=ustar -cf $(RELEASE_FOLDER)/gw_update.tar -C sd_content $$(find sd_content -mindepth 1 -maxdepth 1 -exec basename {} \;)
	@./scripts/gen_release_package.sh
endif
.PHONY: release

ifeq ($(DOCKER),1)
release_sdpush: FORCE
	$(V)$(DOCKER_RUN) $(MAKE) release_sdpush $(_DOCKER_FWDVARS) CHECK_DIRTY_SUBMODULE=0
else
release_sdpush: release
	@$(GNWMANAGER) sdpush --file $(RELEASE_FOLDER)/retro-go_update.bin --dest-path "/" \
		-- start bank1 \
		$(RESET_DBGMCU_CMD)
endif
.PHONY: release_sdpush

monitor:
	@$(GNWMANAGER) monitor --utf8
.PHONY: monitor

flash-monitor: flash
	$(V)$(MAKE) monitor
.PHONY: flash-monitor

# Alias for flash
flash_all: flash

# Transfers save files from the device to the host machine
flash_saves_backup:
	mkdir -p backup
	rm -rf backup/savestate
	@$(GNWMANAGER) pull savestate backup/savestate
	@echo "Backup to \"backup/\" complete."
.PHONY: flash_saves_backup

# Transfers save files from the host machine to the device
flash_saves_restore:
	@$(GNWMANAGER) mkdir savestate -- push savestate backup/savestate/*
	@echo "Restore from \"backup/\" complete."
.PHONY: flash_saves_restore

size: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET)_intflash.bin 
	$(V)printf "Internal Flash Usage (for developers): $(shell cat $(BUILD_DIR)/$(TARGET)_intflash.bin | wc -c) B\n"
	$(V)./scripts/size.sh $<
.PHONY: size

gdb: $(BUILD_DIR)/$(TARGET).elf
	$(GDB) $< -ex "target extended-remote :3333"
.PHONY: gdb

# Flashes intflash *only* and launches gdb afterwards
gdb_intflash: $(BUILD_DIR)/$(TARGET)_intflash.bin
	$(GNWMANAGER) flash $(INTFLASH_ADDRESS) $< -- start $(INTFLASH_ADDRESS) --halt -- gdb
.PHONY: gdb_intflash

dump_screenshot:
	@$(GNWMANAGER) screenshot dump
.PHONY: dump_screenshot

docker_build:
	$(V)docker build --network=host --build-arg ARM_COMPILER_VERSION=$(ARM_COMPILER_VERSION) -f Dockerfile --tag $(DOCKER_IMAGE) .
.PHONY: docker_build

# DEPRECATED: use 'make release DOCKER=1' (SD_CARD=1) or 'make docker_shell' instead.
# This target will be removed in a future release.
docker:
	@echo "WARNING: 'make docker' is deprecated."
	@echo "  Use 'make release DOCKER=1' for a containerized release build (SD_CARD=1)."
	@echo "  Use 'make docker_shell' for an interactive shell in the container."
ifeq ($(SD_CARD),0)
	$(V)$(DOCKER_RUN) bash
else
	$(V)$(DOCKER_RUN) bash -c "make -j\$$(nproc) CHECK_DIRTY_SUBMODULE=0 COVERFLOW=1 SHARED_HIBERNATE_SAVESTATE=1 DISABLE_SPLASH_SCREEN=1 INTFLASH_BANK=2 CHEAT_CODES=1 ZH_CN=1 ZH_TW=1 KO_KR=0 JA_JP=1 release"
endif
.PHONY: docker

# Interactive shell without building release (handy when SD_CARD=1 but you only want the container).
docker_shell:
	$(V)$(DOCKER_RUN) bash
.PHONY: docker_shell

help:
	@echo "Game and Watch Retro Go SD"
	@echo ""
	@echo "Configuration variables:"
	@echo "  EXTFLASH_FORCE_SPI  - Forces the use of legacy SPI mode for the external flash driver"
	@echo "  EXTFLASH_SIZE_MB    - Sets the external flash size in megabytes"
	@echo "  EXTFLASH_SIZE       - Sets the external flash size in bytes (has precedence over EXTFLASH_SIZE_MB)"
	@echo "  LARGE_FLASH         - Sets the external flash size to 16MB  (deprecated)"
	@echo "  SD_CARD             - Use SD Card reader (default=0)"
	@echo "                        set to 1 for auto detect between SD Card reader on spi1 (Design by Tim"
	@echo "                        Schuerewegen) or on ospi1 (Design by *yota9* Vladislav Khmelevsky)"
	@echo "  FILESYSTEM_SIZE     - Sets the littleFS partition flash size in bytes. Defaults to 10% of flash."
	@echo "  FILESYSTEM_OFFSET   - Places the littleFS partition at a specified offset in the external flash. "
	@echo "                        Defaults to placing the partition at the end of flash."
	@echo "						   This value is offset from EXTFLASH_OFFSET."
	@echo "  LITTLEFS_BLOCK_SIZE - Sets the generated littleFS image block/erase size in bytes. Defaults to 4096."
	@echo "                        Only core binaries needed for non-empty roms/<system>/ folders are packed (see scripts/sd_cores_pack.py);"
	@echo "                        use gen_littlefs_image.py --no-cores-filter to pack all of sd_content/cores."
	@echo "  EXTFLASH_OFFSET     - Places the data at an offset in the external flash (useful for dual boot)"
	@echo "                        For SD_CARD=0, EXTFLASH_OFFSET+EXTFLASH_SIZE must be a power of two (bytes)."
	@echo "  INTFLASH_BANK       - Sets the internal flash bank. Valid values {1,2} (default=1)."
	@echo "  INTFLASH_ADDRESS    - Explicit internal flash address. If not provided, derived from INTFLASH_BANK."
	@echo "  BIG_BANK            - Use internal flash bank as undocumented 256k.(default=1, set 0 to 128k)."
	@echo "  COMPRESS            - ROM compression: 0 or lzma (default=lzma). SD_CARD=0: FrogFS uses"
	@echo "                        LZMA ROM payloads unless COMPRESS=0 (saves extflash; needs decoder in fw)."
	@echo "  RESET_DBGMCU        - Configures if DBGMCU should be reset after flashing."
	@echo "                        Set to 0 to disable power saving (default=1)"
	@echo "  CODEPAGE            - Sets codepage to configures default display language.(default=1252)"
	@echo "                        set 932 as Japanese; 936 as simple Chinese; 950 as traditional Chinese;"
	@echo "                        949 as Korean; 12511 as Russian; 12521 as Spanish; 12522 as Portuguese;"
	@echo "                        12523 as French; 12524 as Italian; 12525 as German;"
	@echo "  UICODEPAGE          - Sets ui display language.(default=CODEPAGE=1252 as English)"
	@echo "  ROMINFOCODE         - Sets encoding of parse rom name, default = ascii"
	@echo "  ES_ES,PT_PT,FR_FR,  "
	@echo "  IT_IT,ZH_CN,ZH_TW,  "
	@echo "  KO_KR,JA_JP,DE_DE,  "
	@echo "  RU_RU               - Set to 0 to omit Russian UI and CP1251 fonts on SD /fonts."
	@echo "  SINGLE_FONT         - Set to 1 to only include the default serif font (per codepage)."
	@echo "                        Fewer font sections in firmware and only cp1252_serif.bin (+ cp1251 if RU_RU) on /fonts."
	@echo "                        Unicode fallback .bin files on /fonts follow active ZH_CN,ZH_TW,JA_JP,KO_KR (+ small symbol sets)."
	@echo "  COVERFLOW           - Set to 1 include cover art with rom (default=0)"
	@echo "  JPG_QUALITY         - Set convert cover art image jpg quality (default = 90)"
	@echo "  ENABLE_SCREENSHOT   - Set to 1 to enable screenshot support (default enabled)"
	@echo "  GNW_TARGET          - Game & Watch target, Valid values {mario,zelda} (default=mario)"makefile.
	@echo "  GAME_GENIE          - Set to 1 to enable game genie support (deprecated, use CHEAT_CODES instead)"
	@echo "  CHEAT_CODES         - Set to 1 to enable cheat codes support (default=0)"
	@echo "  MSX_USE_BANK_2      - Set to 1 to use Internal Bank 2 for MSX performance improvements."
	@echo "                        Retro-Go must be in Bank 1."
	@echo "  SHARED_HIBERNATE_SAVESTATE - Set to 1 to enable a separate savestate for off/on (default=0)"
	@echo "  DISABLE_SPLASH_SCREEN - Set to 1 to disable the slash screen animation at startup (default=0)"
	@echo ""
	@echo "Current configuration:"
	@echo "  EXTFLASH_FORCE_SPI=$(EXTFLASH_FORCE_SPI)"
	@echo "  EXTFLASH_SIZE_MB=$(EXTFLASH_SIZE_MB)"
	@echo "  EXTFLASH_SIZE=$(EXTFLASH_SIZE)"
	@echo "  LARGE_FLASH=$(LARGE_FLASH)"
	@echo "  EXTFLASH_OFFSET=$(EXTFLASH_OFFSET)"
	@echo "  INTFLASH_BANK=$(INTFLASH_BANK)"
	@echo "  BIG_BANK=$(BIG_BANK)"
	@echo "  COMPRESS=$(COMPRESS)"
	@echo "  RESET_DBGMCU=$(RESET_DBGMCU)"
	@echo "  ENABLE_SCREENSHOT=$(ENABLE_SCREENSHOT)"
	@echo "  GNW_TARGET=$(GNW_TARGET)"
	@echo "  CHEAT_CODES=$(CHEAT_CODES)"
	@echo "  MSX_USE_BANK_2=$(MSX_USE_BANK_2)"
	@echo "  GCC_PATH=$(GCC_PATH)"
	@echo "  PREFIX=$(PREFIX)"
	@echo "  CODEPAGE=$(CODEPAGE)"
	@echo "  UICODEPAGE=$(UICODEPAGE)"
	@echo "  COVERFLOW=$(COVERFLOW)"
	@echo "  ROMINFOCODE=$(ROMINFOCODE)"
	@echo "  SHARED_HIBERNATE_SAVESTATE=$(SHARED_HIBERNATE_SAVESTATE)"
	@echo "  ES_ES=$(ES_ES)"
	@echo "  PT_PT=$(PT_PT)"
	@echo "  FR_FR=$(FR_FR)"
	@echo "  IT_IT=$(IT_IT)"
	@echo "  RU_RU=$(RU_RU)"
	@echo "  DE_DE=$(DE_DE)"
	@echo "  ZH_CN=$(ZH_CN)"
	@echo "  ZH_TW=$(ZH_TW)"
	@echo "  KO_KR=$(KO_KR)"
	@echo "  JA_JP=$(JA_JP)"
	@echo "  SINGLE_FONT=$(SINGLE_FONT)"
	@echo ""
	@echo "Targets:"
	@echo "  make [target]         - Run target locally (default: build firmware)"
	@echo "  make [target] DOCKER=1 - Run target inside the Docker container instead."
	@echo "                        Applies to: (default), flash, flash_intflash, flash_extflash,"
	@echo "                        flash_sd, release, release_sdpush."
	@echo "  docker_build          - Build the Docker container image"
	@echo "  docker_shell          - Interactive shell in $(DOCKER_IMAGE)"
	@echo "  docker (deprecated)   - Use 'make release DOCKER=1' or 'make docker_shell' instead"
	@echo "  dump_screenshot   - Downloads the stored screenshot."
	@echo "  flash             - Programs the internal and external flash"
	@echo "  flash_all         - Alias for 'flash' (deprecated)"
	@echo "  flash_extflash    - Flash FrogFS image only (SD_CARD=0; respects EXTFLASH_OFFSET)"
	@echo "  flash_intflash    - Only programs the internal flash"
	@echo "  gdb               - Starts gdb and attaches to gdbserver"
	@echo "  gdb_intflash      - Flashes intflash and then starts gdb and attaches to gdbserver"
	@echo "  reset_dbgmcu      - Resets the unit and turns off DBGMCU (lowers battery drain)"
	@echo "  reset_mcu         - Resets the unit"
	@echo "                      publish property under edit that file before make flash "
	@echo "  size              - Prints size information for all sections"
	@echo ""
.PHONY: help

#######################################
# download SDK files
#######################################
$(HAL_DRIVER_DIR)/%: $(HAL_SENTINEL)
	$(V)$(ECHO) [ WGET STM32CubeH7 HAL ] $(notdir $@)
	$(V)mkdir -p $(dir $@)
	$(V)wget -q $(HAL_DRIVER_URL)/$(HAL_DRIVER_VERSION)/$(patsubst $(HAL_DRIVER_DIR)/%,%,$@) -O $@

$(CMSIS_DEVICE_DIR)/%: $(CMSIS_DEV_SENTINEL)
	$(V)$(ECHO) [ WGET STM32CubeH7 CMSIS ] $(notdir $@)
	$(V)mkdir -p $(dir $@)
	$(V)wget -q $(CMSIS_DEVICE_URL)/$(CMSIS_DEVICE_VERSION)/$(patsubst $(CMSIS_DEVICE_DIR)/%,%,$@) -O $@

$(SDK_DIR)/%: $(SDK_SENTINEL)
	$(V)$(ECHO) [ WGET STM32CubeH7 ] $(notdir $@)
	$(V)wget -q $(SDK_URL)/$(SDK_VERSION)/$@ -P $(dir $@)

.PHONY: download_sdk
download_sdk: $(SDK_SENTINEL) $(HAL_SENTINEL) $(CMSIS_DEV_SENTINEL) $(SDK_HEADERS) $(SDK_C_SOURCES) $(SDK_ASM_SOURCES)

#######################################
# clean up
#######################################
clean:
	$(V)$(ECHO) [ RM ] $(BUILD_DIR)
	$(V)-rm -fR $(BUILD_DIR)
	$(V)-rm -fR $(SD_FOLDER)
	$(V)-rm -fR $(RELEASE_FOLDER)
	$(V)$(MAKE) -C external/zelda3 clean
	$(V)$(MAKE) -C external/smw clean
	$(V)@$(MAKE) -C external/firmware_update clean

distclean: clean
	$(V)$(ECHO) [ RM ] $(SDK_DIR)
	$(V)rm -rf $(SDK_DIR)

#######################################
# dependencies
#######################################
-include $(wildcard $(BUILD_DIR)/*.d)

# *** EOF ***
